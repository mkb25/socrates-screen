# ──────────────────────────────────────────────────────────────────────────────
# Socrates Screen – Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Engine (pick ONE; Groq is recommended for lowest latency) ────────────

# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional Groq model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.1-8b-instant

# Get from: https://cloud.cerebras.ai/
# CEREBRAS_API_KEY=csk_xxxxxxxx
# CEREBRAS_MODEL=llama3.1-70b

# ── TMDB ────────────────────────────────────────────────────────────────────
# Get from: https://www.themoviedb.org/settings/api  (use the "API Read Access Token")
TMDB_API_KEY=eyJhbGciOiJIUzI1NiJ9.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudflare Worker ────────────────────────────────────────────────────────
# After deploying worker.js, paste the published URL here.
# Example: https://tmdb-proxy.your-username.workers.dev
CLOUDFLARE_WORKER_URL=https://tmdb-proxy.your-username.workers.dev

# ── CORS (comma-separated list of allowed frontend origins) ─────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
